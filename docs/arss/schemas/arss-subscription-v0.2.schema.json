{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arss.dev/schemas/arss-subscription-v0.2.schema.json",
  "title": "ARSS-Pay Subscription v0.2",
  "type": "object",
  "required": ["type", "feed_url", "agent", "permissions", "budget", "sync"],
  "properties": {
    "type": { "const": "https://arss.dev/subscription/v0.2" },
    "feed_url": { "type": "string", "format": "uri" },
    "subscriber": { "type": "string" },
    "agent": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" }
      },
      "additionalProperties": true
    },
    "permissions": {
      "type": "object",
      "properties": {
        "summarise": { "type": "boolean" },
        "quote": { "enum": [false, true, "limited"] },
        "embed": { "type": "boolean" },
        "store_user_memory": { "type": "boolean" },
        "train_model": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "budget": {
      "type": "object",
      "properties": {
        "max_per_item_usdc": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_per_day_usdc": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_per_month_usdc": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
      },
      "additionalProperties": true
    },
    "sync": {
      "type": "object",
      "properties": {
        "poll": { "type": "string" },
        "push": { "enum": ["none", "websub", "webhook"] }
      },
      "additionalProperties": true
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" }
  },
  "additionalProperties": true
}
